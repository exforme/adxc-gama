#!/usr/bin/env bash

set -e

# Purpose:
#   Create message board entries using a wizard.

ADXC_HOME="${ADXC_HOME:-/opt/adxc}"
. "$ADXC_HOME/lib/adxc-common.sh"

MESSAGE_DIR="$ADXC_HOME/messages"
mkdir -p "$MESSAGE_DIR"

adxc_print_section "CREATE MESSAGE BOARD NOTICE"

printf "Type [INFO/WARNING/CRITICAL]: "
read -r TYPE
TYPE="${TYPE:-INFO}"

printf "Title: "
read -r TITLE
[ -n "$TITLE" ] || { adxc_error "Title is required"; exit 1; }

printf "Text: "
read -r TEXT

printf "Expiration date [YYYY-MM-DD]: "
read -r EXPIRES

NEXT_ID="$(find "$MESSAGE_DIR" -name '*.msg' -printf '%f\n' 2>/dev/null | sed 's/.msg//' | sort -n | tail -1)"
NEXT_ID="${NEXT_ID:-0}"
NEXT_ID=$(printf "%03d" $((10#$NEXT_ID + 1)))
MESSAGE_FILE="$MESSAGE_DIR/$NEXT_ID.msg"

cat <<EOF

Preview:
TYPE=$TYPE
TITLE=$TITLE
TEXT=$TEXT
EXPIRES=$EXPIRES
EOF

printf "Create this message? [y/N]: "
read -r CONFIRM
case "$CONFIRM" in
    y|Y|yes|YES)
        cat > "$MESSAGE_FILE" <<EOF
TYPE=$TYPE
TITLE=$TITLE
TEXT=$TEXT
EXPIRES=$EXPIRES
EOF
        chmod 644 "$MESSAGE_FILE"
        adxc_ok "Message created: $MESSAGE_FILE"
        ;;
    *)
        adxc_warn "Message creation cancelled"
        ;;
esac
