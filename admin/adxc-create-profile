#!/usr/bin/env bash
# ==============================================================================
# adxc-create-profile - create operational profile from template
# ==============================================================================
# Purpose:
#   Create instance profiles such as TQM1, TQM2, DT-PROD.
#
# Templates currently included:
#   - mq_miqm
#   - mq_standalone
#   - dynatrace
#
# Tip:
#   Created profiles are inventory objects and become visible immediately in:
#     adxc
#     adxc-profiles
# ============================================================================== 

set -e

ADXC_HOME=${ADXC_HOME:-/opt/adxc}

# shellcheck source=/dev/null
. "$ADXC_HOME/lib/adxc-colors.sh"

TEMPLATE_DIR="$ADXC_HOME/templates/profile-templates"
PROFILE_DIR="$ADXC_HOME/profiles"

adxc_title "CREATE OPERATIONAL PROFILE"

echo "Available templates:"

select selected_template in $(find "$TEMPLATE_DIR" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort); do
    [ -n "$selected_template" ] && break
done

read -r -p "Profile instance name: " profile_name

if [ -z "$profile_name" ]; then
    adxc_error "Profile name required"
    exit 1
fi

target_dir="$PROFILE_DIR/$profile_name"

if [ -e "$target_dir" ]; then
    adxc_error "Profile already exists: $profile_name"
    exit 1
fi

cp -a "$TEMPLATE_DIR/$selected_template" "$target_dir"

profile_conf="$target_dir/profile.conf"
sed -i "s/__PROFILE_NAME__/$profile_name/g" "$profile_conf"

case "$selected_template" in
    mq_miqm|mq_standalone)
        read -r -p "Queue manager name [$profile_name]: " qmgr_name
        qmgr_name=${qmgr_name:-$profile_name}
        sed -i "s/__QMGR_NAME__/$qmgr_name/g" "$profile_conf"
        ;;
esac

if [ "$selected_template" = "mq_miqm" ]; then
    read -r -p "Primary node: " primary_node
    read -r -p "Secondary node: " secondary_node

    sed -i "s/__PRIMARY_NODE__/$primary_node/g" "$profile_conf"
    sed -i "s/__SECONDARY_NODE__/$secondary_node/g" "$profile_conf"
fi

chmod -R go-rwx "$target_dir"
find "$target_dir/commands" -type f -exec chmod 755 {} \; 2>/dev/null || true

adxc_ok "Profile created: $profile_name from template $selected_template"
echo "Visible immediately in: adxc"
echo "Inventory: adxc-profiles"
