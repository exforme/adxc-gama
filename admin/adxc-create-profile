#!/usr/bin/env bash
set -e; ADXC_HOME=${ADXC_HOME:-/opt/adxc}; . "$ADXC_HOME/lib/adxc-colors.sh"; TPLDIR="$ADXC_HOME/templates/profile-templates"; PROFDIR="$ADXC_HOME/profiles"; adxc_title "CREATE OPERATIONAL PROFILE"; echo "Available templates:"; select tpl in $(find "$TPLDIR" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort); do [ -n "$tpl" ] && break; done; read -rp "Profile instance name: " pname; [ -n "$pname" ] || { adxc_error "Profile name required"; exit 1; }; target="$PROFDIR/$pname"; [ ! -e "$target" ] || { adxc_error "Profile already exists: $pname"; exit 1; }; cp -a "$TPLDIR/$tpl" "$target"; conf="$target/profile.conf"; sed -i "s/__PROFILE_NAME__/$pname/g" "$conf"; case "$tpl" in mq_miqm|mq_standalone) read -rp "Queue manager name [$pname]: " qm; qm=${qm:-$pname}; sed -i "s/__QMGR_NAME__/$qm/g" "$conf";; esac; if [ "$tpl" = mq_miqm ]; then read -rp "Primary node: " n1; read -rp "Secondary node: " n2; sed -i "s/__PRIMARY_NODE__/$n1/g; s/__SECONDARY_NODE__/$n2/g" "$conf"; fi; chmod -R go-rwx "$target"; find "$target/commands" -type f -exec chmod 755 {} \; 2>/dev/null || true; adxc_ok "Profile created: $pname from template $tpl"; echo "Visible immediately in: adxc"; echo "Inventory: adxc-profiles"
