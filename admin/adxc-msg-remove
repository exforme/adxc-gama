#!/usr/bin/env bash
set -e
ADXC_HOME=${ADXC_HOME:-/opt/adxc}; . "$ADXC_HOME/lib/adxc-common.sh"; adxc_load_user_config
case "$ADXC_ROLE" in admin|ADMIN|root) ;; *) adxc_error "adxc-msg-remove requires admin role"; exit 1;; esac
id=${1:-}
if [ -z "$id" ]; then "$ADXC_HOME/admin/adxc-msg-list"; read -rp "Message ID : " id; fi
file="$ADXC_HOME/messages/$id.msg"; [ -f "$file" ] || { adxc_error "Message not found: $id"; exit 1; }
title=$(adxc_message_field "$file" TITLE "Untitled message")
read -rp "Remove message '$title' (Y/N)? " yn
case "$yn" in Y|y|YES|yes) rm -f "$file"; adxc_ok "Message removed: $id";; *) echo "Message removal cancelled.";; esac
