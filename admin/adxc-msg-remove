#!/usr/bin/env bash
# ==============================================================================
# adxc-msg-remove - remove a dashboard Message Board entry
# ============================================================================== 

set -e

ADXC_HOME=${ADXC_HOME:-/opt/adxc}

# shellcheck source=/dev/null
. "$ADXC_HOME/lib/adxc-common.sh"

adxc_load_user_config

case "$ADXC_ROLE" in
    admin|ADMIN|root) ;;
    *)
        adxc_error "adxc-msg-remove requires admin role"
        exit 1
        ;;
esac

message_id="${1:-}"

if [ -z "$message_id" ]; then
    "$ADXC_HOME/admin/adxc-msg-list"
    read -r -p "Message ID : " message_id
fi

message_file="$ADXC_HOME/messages/$message_id.msg"

if [ ! -f "$message_file" ]; then
    adxc_error "Message not found: $message_id"
    exit 1
fi

message_title=$(adxc_message_field "$message_file" TITLE "Untitled message")
read -r -p "Remove message '$message_title' (Y/N)? " confirm

case "$confirm" in
    Y|y|YES|yes)
        rm -f "$message_file"
        adxc_ok "Message removed: $message_id"
        ;;
    *)
        echo "Message removal cancelled."
        ;;
esac
