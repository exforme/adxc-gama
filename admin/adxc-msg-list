#!/usr/bin/env bash
# ==============================================================================
# adxc-msg-list - list active message-board entries
# ============================================================================== 

ADXC_HOME=${ADXC_HOME:-/opt/adxc}

# shellcheck source=/dev/null
. "$ADXC_HOME/lib/adxc-common.sh"

adxc_load_user_config

case "$ADXC_ROLE" in
    admin|ADMIN|root) ;;
    *)
        adxc_error "adxc-msg-list requires admin role"
        exit 1
        ;;
esac

count=$(adxc_active_message_count)
adxc_title "ACTIVE MESSAGES ($count)"

if [ "$count" -eq 0 ]; then
    echo "No active messages."
    adxc_line
    exit 0
fi

for message_file in $(ls "$ADXC_HOME/messages"/*.msg 2>/dev/null | sort); do
    [ -f "$message_file" ] || continue
    adxc_message_active "$message_file" || continue

    message_id=$(basename "$message_file" .msg)
    message_type=$(adxc_message_field "$message_file" TYPE INFO)
    message_title=$(adxc_message_field "$message_file" TITLE "Untitled message")
    expires=$(adxc_message_field "$message_file" EXPIRES "9999-12-31")

    printf ' %s  %-8s\n' "$message_id" "$message_type"
    printf '      %s\n' "$message_title"
    printf '      Expires : %s\n' "$expires"
    adxc_sep
done

adxc_line
