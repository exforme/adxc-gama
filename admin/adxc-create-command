#!/usr/bin/env bash
set -e; ADXC_HOME=${ADXC_HOME:-/opt/adxc}; . "$ADXC_HOME/lib/adxc-colors.sh"; adxc_title "CREATE CUSTOM COMMAND"; read -rp "Command name: " cname; [ -n "$cname" ] || { adxc_error "Command name required"; exit 1; }; read -rp "Target profile or GLOBAL [GLOBAL]: " target; target=${target:-GLOBAL}; if [ "$target" = GLOBAL ] || [ "$target" = global ]; then dir="$ADXC_HOME/commands/global"; else dir="$ADXC_HOME/profiles/$target/commands"; [ -d "$dir" ] || { adxc_error "Target profile not found: $target"; exit 1; }; fi; file="$dir/$cname"; [ ! -e "$file" ] || { adxc_error "Command already exists: $file"; exit 1; }; cp "$ADXC_HOME/templates/command-templates/basic-command.sh" "$file"; sed -i "s/__COMMAND_NAME__/$cname/g" "$file"; chmod 755 "$file"; adxc_ok "Custom command created: $file"; echo "List commands: adxc-cmd"
