#!/usr/bin/env bash
# ==============================================================================
# adxc-create-command - create global or profile-specific custom command
# ==============================================================================
# Purpose:
#   Generate a command skeleton from templates/command-templates/basic-command.sh.
#
# Examples:
#   Target profile: GLOBAL
#       Creates /opt/adxc/commands/global/<command>
#
#   Target profile: TQM1
#       Creates /opt/adxc/profiles/TQM1/commands/<command>
# ============================================================================== 

set -e

ADXC_HOME=${ADXC_HOME:-/opt/adxc}

# shellcheck source=/dev/null
. "$ADXC_HOME/lib/adxc-colors.sh"

adxc_title "CREATE CUSTOM COMMAND"

read -r -p "Command name: " command_name

if [ -z "$command_name" ]; then
    adxc_error "Command name required"
    exit 1
fi

read -r -p "Target profile or GLOBAL [GLOBAL]: " target_profile
target_profile=${target_profile:-GLOBAL}

if [ "$target_profile" = "GLOBAL" ] || [ "$target_profile" = "global" ]; then
    target_dir="$ADXC_HOME/commands/global"
else
    target_dir="$ADXC_HOME/profiles/$target_profile/commands"

    if [ ! -d "$target_dir" ]; then
        adxc_error "Target profile not found: $target_profile"
        exit 1
    fi
fi

target_file="$target_dir/$command_name"

if [ -e "$target_file" ]; then
    adxc_error "Command already exists: $target_file"
    exit 1
fi

cp "$ADXC_HOME/templates/command-templates/basic-command.sh" "$target_file"
sed -i "s/__COMMAND_NAME__/$command_name/g" "$target_file"
chmod 755 "$target_file"

adxc_ok "Custom command created: $target_file"
echo "List commands: adxc-cmd"
