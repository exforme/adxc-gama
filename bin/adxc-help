#!/usr/bin/env bash
ADXC_HOME=${ADXC_HOME:-/opt/adxc}
. "$ADXC_HOME/lib/adxc-common.sh"
adxc_load_user_config

print_desc() {
  f="$1"
  grep -m1 '^# DESC:' "$f" 2>/dev/null | sed 's/^# DESC:[ ]*//'
}

count_total=0
inc_count() { count_total=$((count_total+1)); }

show_first_level() {
  adxc_title "aDXC-GAMA HELP"
  printf '%b\n' "${ADXC_CYAN}FIRST LEVEL MENUS / ENTRY POINTS${ADXC_RESET}"
  adxc_sep
  printf ' %-18b %s\n' "${ADXC_GREEN}adxc${ADXC_RESET}" "Main dashboard"
  printf ' %-18b %s\n' "${ADXC_GREEN}adxc-os${ADXC_RESET}" "Linux health checks and diagnostics"
  printf ' %-18b %s\n' "${ADXC_GREEN}adxc-cmd${ADXC_RESET}" "Custom command catalog"
  printf ' %-18b %s\n' "${ADXC_GREEN}adxc-profiles${ADXC_RESET}" "Operational profile inventory"
  printf ' %-18b %s\n' "${ADXC_GREEN}adxc-help${ADXC_RESET}" "Help and command inventory"
  case "$ADXC_ROLE" in
    admin|ADMIN|root)
      printf ' %-18b %s\n' "${ADXC_GREEN}adxc-admin${ADXC_RESET}" "Framework administration"
      ;;
  esac
  adxc_line
  echo "Use: adxc-help --list-all"
  echo "To list all commands currently available for this user."
}

show_list_all() {
  user=$(id -un)
  host=$(hostname 2>/dev/null || uname -n 2>/dev/null || cat /proc/sys/kernel/hostname 2>/dev/null || echo unknown)
  ver=$(adxc_version)
  global_count=0
  profile_count=0
  admin_count=0

  adxc_title "AVAILABLE COMMANDS"
  printf ' User    : %s\n' "$user"
  printf ' Host    : %s\n' "$host"
  printf ' Role    : %s\n' "$ADXC_ROLE"
  printf ' Version : %s\n' "$ver"

  adxc_section "DASHBOARD / HELP"
  printf ' %-28b %s\n' "${ADXC_GREEN}adxc${ADXC_RESET}" "Open main GAMA dashboard"; inc_count
  printf ' %-28b %s\n' "${ADXC_GREEN}adxc-help${ADXC_RESET}" "Show first-level help"; inc_count
  printf ' %-28b %s\n' "${ADXC_GREEN}adxc-help --list-all${ADXC_RESET}" "List all commands available for current user"; inc_count

  adxc_section "OPERATIONAL OBJECTS"
  printf ' %-28b %s\n' "${ADXC_GREEN}adxc-os${ADXC_RESET}" "Linux health checks and diagnostics"; inc_count

  adxc_section "PROFILE COMMANDS"
  found_profile_cmd=0
  for pdir in "$ADXC_HOME/profiles"/*; do
    [ -d "$pdir" ] || continue
    prof=$(basename "$pdir")
    adxc_profile_allowed "$prof" || continue
    cdir="$pdir/commands"
    [ -d "$cdir" ] || continue
    printed_header=0
    for f in "$cdir"/*; do
      [ -x "$f" ] || continue
      cmd=$(basename "$f")
      desc=$(print_desc "$f")
      [ -n "$desc" ] || desc="Profile command"
      if [ "$printed_header" -eq 0 ]; then
        printf '%b\n' "${ADXC_CYAN}$prof${ADXC_RESET}"
        printed_header=1
      fi
      printf ' %-28b %s\n' "${ADXC_GREEN}adxc-cmd $prof/$cmd${ADXC_RESET}" "$desc"
      found_profile_cmd=1
      profile_count=$((profile_count+1)); inc_count
    done
    [ "$printed_header" -eq 1 ] && echo
  done
  [ "$found_profile_cmd" -eq 1 ] || printf '%b\n' "${ADXC_YELLOW}No assigned profile commands available for this user.${ADXC_RESET}"

  adxc_section "CUSTOM COMMANDS"
  found_global=0
  for f in "$ADXC_HOME/commands/global"/*; do
    [ -x "$f" ] || continue
    cmd=$(basename "$f")
    desc=$(print_desc "$f")
    [ -n "$desc" ] || desc="Global custom command"
    printf ' %-28b %s\n' "${ADXC_GREEN}adxc-cmd $cmd${ADXC_RESET}" "$desc"
    found_global=1
    global_count=$((global_count+1)); inc_count
  done
  [ "$found_global" -eq 1 ] || printf '%b\n' "${ADXC_YELLOW}No global custom commands available.${ADXC_RESET}"

  case "$ADXC_ROLE" in
    admin|ADMIN|root)
      adxc_section "ADMINISTRATION"
      for item in \
        "adxc-admin|Framework administration main menu" \
        "adxc-admin messages|Message Board Management submenu" \
        "adxc-profiles|List operational profile inventory" \
        "adxc-create-profile|Create operational profile from template" \
        "adxc-create-command|Create global or profile-specific custom command" \
        "adxc-enable-user.sh|Enable aDXC runtime for a user" \
        "adxc-disable-user.sh|Disable aDXC runtime for a user" \
        "adxc-msg-list|List active dashboard messages" \
        "adxc-msg-create|Create dashboard message with wizard" \
        "adxc-msg-remove|Remove dashboard message" \
        "adxc-msg-cleanup|Remove expired dashboard messages"
      do
        cmd=${item%%|*}; desc=${item#*|}
        printf ' %-28b %s\n' "${ADXC_GREEN}$cmd${ADXC_RESET}" "$desc"
        admin_count=$((admin_count+1)); inc_count
      done
      ;;
    *)
      adxc_section "ADMINISTRATION"
      printf '%b\n' "${ADXC_DIM}Not available for this role.${ADXC_RESET}"
      ;;
  esac

  adxc_section "SUMMARY"
  printf ' %-22s : %s\n' "Global Commands" "$global_count"
  printf ' %-22s : %s\n' "Profile Commands" "$profile_count"
  printf ' %-22s : %s\n' "Admin Commands" "$admin_count"
  printf ' %-22s : %s\n' "Total Available" "$count_total"
  adxc_line
}

case "${1:-}" in
  --list-all|-list-all|list-all) show_list_all ;;
  *) show_first_level ;;
esac
