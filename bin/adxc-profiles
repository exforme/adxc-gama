#!/usr/bin/env bash
# ==============================================================================
# adxc-profiles - list configured operational profiles
# ============================================================================== 

ADXC_HOME=${ADXC_HOME:-/opt/adxc}

# shellcheck source=/dev/null
. "$ADXC_HOME/lib/adxc-common.sh"

adxc_load_user_config

adxc_title "PROFILE INVENTORY"

found=0

for profile_dir in "$ADXC_HOME/profiles"/*; do
    [ -d "$profile_dir" ] || continue
    found=1

    profile_name=$(basename "$profile_dir")
    profile_conf="$profile_dir/profile.conf"

    profile_type=$(adxc_profile_field "$profile_conf" PROFILE_TYPE custom)
    profile_desc=$(adxc_profile_field "$profile_conf" PROFILE_DESCRIPTION "Operational profile")
    qmgr_name=$(adxc_profile_field "$profile_conf" QMGR_NAME -)
    primary_node=$(adxc_profile_field "$profile_conf" PRIMARY_NODE -)
    secondary_node=$(adxc_profile_field "$profile_conf" SECONDARY_NODE -)

    if adxc_profile_allowed "$profile_name"; then
        access="allowed"
    else
        access="inventory"
    fi

    printf '%b\n' "${ADXC_CYAN}$profile_name${ADXC_RESET}"
    printf '  %-14s : %s\n' "Description" "$profile_desc"
    printf '  %-14s : %s\n' "Type" "$profile_type"
    printf '  %-14s : %s\n' "Access" "$access"

    [ "$qmgr_name" != "-" ] && printf '  %-14s : %s\n' "Queue Manager" "$qmgr_name"
    [ "$primary_node" != "-" ] && printf '  %-14s : %s\n' "Primary Node" "$primary_node"
    [ "$secondary_node" != "-" ] && printf '  %-14s : %s\n' "Secondary Node" "$secondary_node"

    adxc_sep
done

if [ "$found" -ne 1 ]; then
    printf '%b\n' "${ADXC_YELLOW}No operational profiles configured yet.${ADXC_RESET}"
fi

adxc_line
