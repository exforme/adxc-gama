#!/usr/bin/env bash

###############################################################################
# aDXC-GAMA Profile Inventory
###############################################################################

ADXC_HOME="${ADXC_HOME:-/opt/adxc}"

. "$ADXC_HOME/lib/adxc-common.sh"

adxc_load_user_config

###############################################################################
# Header
###############################################################################

adxc_title "PROFILE INVENTORY"

FOUND=0

###############################################################################
# Profile Loop
###############################################################################

for PROFILE_DIR in "$ADXC_HOME/profiles"/*
do
    [ -d "$PROFILE_DIR" ] || continue

    FOUND=1

    PROFILE_NAME="$(basename "$PROFILE_DIR")"

    PROFILE_CONF="$PROFILE_DIR/profile.conf"

    PROFILE_TYPE="$(
        adxc_profile_field \
            "$PROFILE_CONF" \
            PROFILE_TYPE \
            custom
    )"

    PROFILE_DESCRIPTION="$(
        adxc_profile_field \
            "$PROFILE_CONF" \
            PROFILE_DESCRIPTION \
            "Operational profile"
    )"

    QMGR_NAME="$(
        adxc_profile_field \
            "$PROFILE_CONF" \
            QMGR_NAME \
            -
    )"

    PRIMARY_NODE="$(
        adxc_profile_field \
            "$PROFILE_CONF" \
            PRIMARY_NODE \
            -
    )"

    SECONDARY_NODE="$(
        adxc_profile_field \
            "$PROFILE_CONF" \
            SECONDARY_NODE \
            -
    )"

    if adxc_profile_allowed "$PROFILE_NAME"
    then
        ACCESS_LEVEL="allowed"
    else
        ACCESS_LEVEL="inventory"
    fi

    ###########################################################################
    # Display Profile
    ###########################################################################

    printf '%b\n' \
        "${ADXC_CYAN}${PROFILE_NAME}${ADXC_RESET}"

    printf \
        '  %-14s : %s\n' \
        "Description" \
        "$PROFILE_DESCRIPTION"

    printf \
        '  %-14s : %s\n' \
        "Type" \
        "$PROFILE_TYPE"

    printf \
        '  %-14s : %s\n' \
        "Access" \
        "$ACCESS_LEVEL"

    if [ "$QMGR_NAME" != "-" ]
    then
        printf \
            '  %-14s : %s\n' \
            "Queue Manager" \
            "$QMGR_NAME"
    fi

    if [ "$PRIMARY_NODE" != "-" ]
    then
        printf \
            '  %-14s : %s\n' \
            "Primary Node" \
            "$PRIMARY_NODE"
    fi

    if [ "$SECONDARY_NODE" != "-" ]
    then
        printf \
            '  %-14s : %s\n' \
            "Secondary Node" \
            "$SECONDARY_NODE"
    fi

    adxc_sep

done

###############################################################################
# No Profiles Found
###############################################################################

if [ "$FOUND" -eq 0 ]
then
    printf '%b\n' \
        "${ADXC_YELLOW}No operational profiles configured yet.${ADXC_RESET}"
fi

###############################################################################
# Footer
###############################################################################

adxc_line
