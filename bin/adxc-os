#!/usr/bin/env bash
ADXC_HOME=${ADXC_HOME:-/opt/adxc}; . "$ADXC_HOME/lib/adxc-common.sh"; adxc_load_user_config
adxc_title "OS - Linux health checks and diagnostics"
printf '%-18s : %s\n' Hostname "$(hostname)" Kernel "$(uname -r)" Uptime "$(uptime -p 2>/dev/null || uptime)"
adxc_section FILESYSTEMS; df -hP | awk 'NR==1 || $5+0 >= 80 {print}'
adxc_section "NFS MOUNTS"; mount | grep -i nfs || echo "No NFS mounts found"
adxc_line
