#!/usr/bin/env bash
# -----------------------------------------------------------------------------
# aDXC-GAMA command registry viewer
# -----------------------------------------------------------------------------

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ADXC_ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

if [[ "${1:-}" != "--list" ]]; then
    printf 'Usage: adxc-cmd --list\n'
    exit 0
fi

printf 'GLOBAL COMMANDS\n'
find "${ADXC_ROOT_DIR}/commands/global" -mindepth 1 -maxdepth 1 -type f -printf '  %f\n' | sort
printf '\nPROFILE COMMANDS\n'
find "${ADXC_ROOT_DIR}/profiles" -path '*/commands/*' -type f ! -name 'README.md' -printf '  %P\n' | sort
