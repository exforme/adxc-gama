#!/usr/bin/env bash
# -----------------------------------------------------------------------------
# aDXC-GAMA command registry viewer and runner
# -----------------------------------------------------------------------------
# Lists command objects, lists profile attachments and runs attached commands.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ADXC_ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
# shellcheck source=../lib/adxc-common.sh
source "${ADXC_ROOT_DIR}/lib/adxc-common.sh"

adxc_usage() {
    printf 'Usage:\n'
    printf '  adxc-cmd --list\n'
    printf '  adxc-cmd --profile <PROFILE>\n'
    printf '  adxc-cmd --run <PROFILE> <COMMAND> [args...]\n'
}

adxc_list_all_commands() {
    printf 'COMMAND REPOSITORY\n'
    find "${ADXC_COMMANDS_DIR}" -mindepth 1 -maxdepth 1 -type f -name '*.cmd' -printf '  %f\n' | sort
    printf '\nGLOBAL HELPER COMMANDS\n'
    find "${ADXC_COMMANDS_DIR}/global" -mindepth 1 -maxdepth 1 -type f -printf '  %f\n' | sort
}

adxc_list_profile_commands() {
    local profile_name="$1"
    local profile_dir="${ADXC_PROFILES_DIR}/${profile_name}"
    local link_files=()
    local link_file

    if [[ ! -d "${profile_dir}" ]]; then
        adxc_print_error "Profile not found: ${profile_name}"
        exit 1
    fi

    printf 'ATTACHED COMMANDS FOR %s\n' "${profile_name}"
    mapfile -t link_files < <(find "${profile_dir}/commands" -mindepth 1 -maxdepth 1 -type f -name '*.link' 2>/dev/null | sort)

    if [[ "${#link_files[@]}" -eq 0 ]]; then
        printf '  No commands attached.\n'
        return 0
    fi

    for link_file in "${link_files[@]}"; do
        COMMAND_NAME=""
        COMMAND_FILE=""
        # shellcheck source=/dev/null
        source "${link_file}"
        printf '  %-24s %s\n' "${COMMAND_NAME}" "${COMMAND_FILE}"
    done
}

adxc_run_profile_command() {
    local profile_name="$1"
    local command_name="$2"
    shift 2
    local profile_dir="${ADXC_PROFILES_DIR}/${profile_name}"
    local link_file="${profile_dir}/commands/${command_name}.link"
    local command_file

    if [[ ! -f "${link_file}" ]]; then
        adxc_print_error "Command ${command_name} is not attached to profile ${profile_name}."
        exit 1
    fi

    COMMAND_FILE=""
    # shellcheck source=/dev/null
    source "${link_file}"
    command_file="${ADXC_ROOT_DIR}/${COMMAND_FILE}"

    if [[ ! -x "${command_file}" ]]; then
        adxc_print_error "Command file is not executable or missing: ${command_file}"
        exit 1
    fi

    "${command_file}" "$@"
}

case "${1:-}" in
    --list)
        adxc_list_all_commands
        ;;
    --profile)
        [[ -n "${2:-}" ]] || { adxc_usage; exit 1; }
        adxc_list_profile_commands "$2"
        ;;
    --run)
        [[ -n "${2:-}" && -n "${3:-}" ]] || { adxc_usage; exit 1; }
        adxc_run_profile_command "$2" "$3" "${@:4}"
        ;;
    *)
        adxc_usage
        ;;
esac
