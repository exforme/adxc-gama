#!/usr/bin/env bash
ADXC_HOME=${ADXC_HOME:-/opt/adxc}; . "$ADXC_HOME/lib/adxc-common.sh"; adxc_load_user_config
case "$ADXC_ROLE" in admin|ADMIN|root) ;; *) adxc_error "adxc-admin requires admin role"; exit 1;; esac
show_main(){ adxc_title "FRAMEWORK ADMINISTRATION"; echo " [1] Profile Management"; echo; echo " [2] User Management"; echo; echo " [3] Command Management"; echo; echo " [4] Message Board Management"; echo; echo " [X] Exit"; adxc_line; }
show_msg(){ adxc_title "MESSAGE BOARD MANAGEMENT"; echo " Active Messages : $(adxc_active_message_count)"; echo; echo " [1] List Active Messages"; echo; echo " [2] Create Message"; echo; echo " [3] Remove Message"; echo; echo " [4] Cleanup Expired Messages"; echo; echo " [X] Back"; adxc_line; }
case "${1:-}" in messages|msg) show_msg;; *) show_main;; esac
