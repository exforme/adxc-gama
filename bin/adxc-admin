#!/usr/bin/env bash
ADXC_HOME="${ADXC_HOME:-/opt/adxc}"
. "$ADXC_HOME/lib/adxc-common.sh"
. "$ADXC_HOME/lib/adxc-profiles.sh"
. "$ADXC_HOME/lib/adxc-commands.sh"
adxc_load_user_config
adxc_require_admin_role
while true; do
    adxc_print_section "GAMA ADMINISTRATION"
    cat <<EOF
[1] List Profiles
[2] List Commands
[q] Quit
EOF
    printf "Select: "
    read -r choice
    case "$choice" in
        1) adxc_print_section "CONFIGURED PROFILES"; adxc_list_profiles_table ;;
        2) adxc_print_section "COMMAND REGISTRY"; adxc_list_command_registry ;;
        q|Q) exit 0 ;;
        *) adxc_warn "Unknown selection: $choice" ;;
    esac
    printf "\nPress ENTER to continue..."
    read -r _
done
