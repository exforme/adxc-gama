#!/usr/bin/env bash
# ==============================================================================
# adxc - main aDXC-GAMA dashboard
# ==============================================================================
# Purpose:
#   Display the compact GAMA operations console.
#
# Layout:
#   1. Compact header
#   2. Message Board
#   3. Operational objects
#   4. Tools
#   5. Administration entry, admin role only
# ==============================================================================

ADXC_HOME=${ADXC_HOME:-/opt/adxc}

# shellcheck source=/dev/null
. "$ADXC_HOME/lib/adxc-common.sh"

adxc_load_user_config

version=$(adxc_version)
host_name=$(adxc_hostname)
user_name=$(id -un)

adxc_title "aDXC-GAMA"
printf ' %b[%s]%b %s@%s%*s%s\n\n' \
    "$ADXC_GREEN" \
    "${ADXC_ROLE^^}" \
    "$ADXC_RESET" \
    "$user_name" \
    "$host_name" \
    20 \
    "" \
    "v$version"

adxc_render_message_board

adxc_section "OPERATIONAL OBJECTS"
adxc_list_profiles_compact

adxc_section "TOOLS"
printf ' [C]  %-14b %s\n\n' "${ADXC_GREEN}adxc-cmd${ADXC_RESET}" "Custom Commands"
printf ' [P]  %-14b %s\n\n' "${ADXC_GREEN}adxc-profiles${ADXC_RESET}" "Profile Inventory"
printf ' [H]  %-14b %s\n' "${ADXC_GREEN}adxc-help${ADXC_RESET}" "Help and command inventory"

case "$ADXC_ROLE" in
    admin|ADMIN|root)
        adxc_section "ADMINISTRATION"
        printf ' [A]  %-14b %s\n' "${ADXC_GREEN}adxc-admin${ADXC_RESET}" "Framework Administration"
        ;;
    *)
        adxc_section "ADMINISTRATION"
        printf '%b\n' "${ADXC_DIM} Not Available${ADXC_RESET}"
        ;;
esac

adxc_line
