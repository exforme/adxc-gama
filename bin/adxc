#!/usr/bin/env bash

# Purpose:
#   Main entry point for aDXC-GAMA dashboard and profile navigation.

ADXC_HOME="${ADXC_HOME:-/opt/adxc}"
. "$ADXC_HOME/lib/adxc-common.sh"
. "$ADXC_HOME/lib/adxc-message-board.sh"
. "$ADXC_HOME/lib/adxc-commands.sh"
. "$ADXC_HOME/lib/adxc-profiles.sh"
. "$ADXC_HOME/lib/adxc-dashboard.sh"

adxc_load_user_config

case "${1:-}" in
    --menu)
        adxc_interactive_profile_menu
        ;;
    "")
        adxc_render_dashboard
        ;;
    *)
        if adxc_profile_exists "$1"; then
            adxc_profile_menu "$1"
        else
            adxc_error "Profile not found: $1"
            exit 1
        fi
        ;;
esac
